@model Compra

<div class="container text-white">
    <h2>Nueva Compra</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label>Proveedor</label>
            <select name="ProveedorId" class="form-control">
                @foreach (var p in ViewBag.Proveedores)
                {
                    <option value="@p.ProveedorId">@p.Nombre</option>
                }
            </select>
        </div>

        <hr />

        <div class="row mb-3">
            <div class="col-md-4">
                <label>Costo de Envío</label>
                <input type="number" step="0.01" name="CostoEnvio" id="costoEnvio" class="form-control" value="0" placeholder="Costo de envío" />
            </div>
        </div>

        <h4>Agregar Producto</h4>

        <div class="row">
            <div class="col">
                <select id="producto" class="form-control">
                    @foreach (var prod in ViewBag.Productos)
                    {
                        <option value="@prod.ProductoId">
                            @prod.Nombre
                        </option>
                    }
                </select>
            </div>

            <div class="col">
                <input type="number" id="cantidad" class="form-control" placeholder="Cantidad" />
            </div>

            <!-- 🔥 NUEVO INPUT -->
            <div class="col">
                <input type="number" step="0.01" id="precioUnitario" class="form-control" placeholder="Precio unitario" />
            </div>

            <!-- 🆕 NUEVO: Checkbox para oferta -->
            <div class="col">
                <div class="form-check" style="margin-top: 0.375rem;">
                    <input type="checkbox" id="esOfertado" class="form-check-input" />
                    <label class="form-check-label" for="esOfertado">
                        ¿Oferta?
                    </label>
                </div>
            </div>

            <div class="col">
                <button type="button" onclick="agregarProducto()" class="btn btn-success">
                    Agregar
                </button>
            </div>
        </div>

        <hr />

        <table class="table table-dark" id="tabla">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>Subtotal</th>
                    <th>¿Oferta?</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <h4>Total: Q <span id="total">0</span></h4>
        <p class="text-muted">Incluye costo de envío</p>

        <input type="hidden" name="Total" id="totalInput" />
        <input type="hidden" name="DetalleJson" id="detalleJson" />

        <button type="submit" class="btn btn-primary">Guardar Compra</button>
    </form>
</div>

<script>
    let subtotalProductos = 0;
    let detalles = [];

    function actualizarTotal() {
        let costoEnvio = parseFloat(document.getElementById("costoEnvio").value) || 0;
        let total = subtotalProductos + costoEnvio;

        document.getElementById("total").innerText = total.toFixed(2);
        document.getElementById("totalInput").value = total;
    }

    function agregarProducto() {
        let select = document.getElementById("producto");
        let cantidad = parseInt(document.getElementById("cantidad").value);
        let precioUnitario = parseFloat(document.getElementById("precioUnitario").value);
        let esOfertado = document.getElementById("esOfertado").checked; // 🆕

        if (!cantidad || cantidad <= 0) {
            alert("Ingrese una cantidad válida");
            return;
        }

        if (!precioUnitario || precioUnitario <= 0) {
            alert("Ingrese un precio válido");
            return;
        }

        let productoId = parseInt(select.value);

        let existe = detalles.find(d => d.ProductoId == productoId);

        if (existe) {
            alert("Este producto ya está agregado");
            return;
        }

        let texto = select.options[select.selectedIndex].text;
        let subtotal = cantidad * precioUnitario;
        subtotalProductos += subtotal;

        actualizarTotal();

        detalles.push({
            ProductoId: productoId,
            Cantidad: cantidad,
            PrecioUnitario: precioUnitario,
            EsOfertado: esOfertado
        });

        document.getElementById("detalleJson").value = JSON.stringify(detalles);

        let index = detalles.length - 1;
        let badgeOferta = esOfertado ? '<span class="badge bg-warning text-dark">SÍ</span>' : '<span class="badge bg-secondary">NO</span>';

        let fila = `
            <tr id="fila-${index}">
                <td>${texto}</td>
                <td>${cantidad}</td>
                <td>${precioUnitario}</td>
                <td>${subtotal}</td>
                <td>${badgeOferta}</td>
                <td>
                    <button type="button" class="btn btn-danger btn-sm" onclick="eliminarProducto(${index}, ${subtotal})">
                        X
                    </button>
                </td>
            </tr>
        `;

        document.querySelector("#tabla tbody").innerHTML += fila;
        
        // Limpiar campos después de agregar
        document.getElementById("cantidad").value = "";
        document.getElementById("precioUnitario").value = "";
        document.getElementById("esOfertado").checked = false;
        document.getElementById("producto").focus();
    }

    function eliminarProducto(index, subtotal) {
        detalles.splice(index, 1);
        subtotalProductos -= subtotal;
        actualizarTotal();

        // Recalcular índices después del splice
        let filas = document.querySelectorAll("#tabla tbody tr");
        filas[index]?.remove();

        document.getElementById("detalleJson").value = JSON.stringify(detalles);
    }

    document.getElementById("costoEnvio").addEventListener("input", actualizarTotal);
</script>