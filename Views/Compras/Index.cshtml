@model List<Compra>

<div class="container-fluid text-white mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>📦 Compras</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-success mb-3">+ Nueva Compra</a>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>ID Compra</th>
                        <th>Proveedor</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Productos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.CompraId</strong></td>
                            <td>@item.Proveedor?.Nombre ?? "Sin proveedor"</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-info">Q @item.Total.ToString("F2")</span>
                            </td>
                            <td>
                                <small>@item.Detalles?.Count() productos</small>
                            </td>
                            <td>
                                <a href="#" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#detallesModal_@item.CompraId">
                                    Ver Detalles
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 🆕 MODALES DE DETALLES -->
        @foreach (var item in Model)
        {
            <div class="modal fade" id="detallesModal_@item.CompraId" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content bg-dark">
                        <div class="modal-header border-info">
                            <h5 class="modal-title">📋 Detalles Compra #@item.CompraId</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p><strong>Proveedor:</strong> @item.Proveedor?.Nombre</p>
                                    <p><strong>Fecha:</strong> @item.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                                <div class="col-md-6">
                                    <p><strong>Total:</strong> <span class="badge bg-success">Q @item.Total.ToString("F2")</span></p>
                                    <p><strong>Envío:</strong> Q @item.CostoEnvio.ToString("F2")</p>
                                </div>
                            </div>

                            <hr />

                            <!-- 🆕 TABLA DE PRODUCTOS CON PRECIOS Y LOTES -->
                            <h6>Productos Comprados:</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-dark">
                                    <thead>
                                        <tr>
                                            <th>Producto</th>
                                            <th>Cantidad</th>
                                            <th>Precio Unitario</th>
                                            <th>Subtotal</th>
                                            <th>¿Oferta?</th>
                                            <th>Número de Lote</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var detalle in item.Detalles ?? new List<DetalleCompra>())
                                        {
                                            <tr>
                                                <td>@detalle.Producto?.Nombre ?? "N/A"</td>
                                                <td>@detalle.Cantidad</td>
                                                <td><strong>Q @detalle.PrecioUnitario.ToString("F2")</strong></td>
                                                <td>Q @(detalle.PrecioUnitario * detalle.Cantidad).ToString("F2")</td>
                                                <td>
                                                    @if (detalle.EsOfertado)
                                                    {
                                                        <span class="badge bg-warning text-dark">✓ SÍ</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">✗ NO</span>
                                                    }
                                                </td>
                                                <td>
                                                    <code>@detalle.NumeroLote</code>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            No hay compras registradas. <a href="@Url.Action("Create")">Crear primera compra</a>
        </div>
    }
</div>