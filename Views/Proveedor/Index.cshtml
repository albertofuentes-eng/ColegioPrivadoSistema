@model IEnumerable<Proveedor>

@{
    ViewData["Title"] = "Proveedores";
}

<h1>Proveedores</h1>

<p>
    <a asp-action="Create">Crear Nuevo Proveedor</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@(item.Activo ? "Activo" : "Inactivo")</td>
                <td>
                    <form asp-action="ToggleActivo" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.ProveedorId" />
                        <button type="submit" class="btn btn-sm @(item.Activo ? "btn-warning" : "btn-success")">
                            @(item.Activo ? "Desactivar" : "Activar")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>