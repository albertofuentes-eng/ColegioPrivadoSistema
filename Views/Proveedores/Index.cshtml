@model IEnumerable<Proveedor>

<div class="container text-white">
    <h2>Proveedores</h2>

    <a href="/Proveedores/Create" class="btn btn-success mb-3">
        + Nuevo Proveedor
    </a>

    <table class="table table-dark">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Dirección</th>
                <th>Estado</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Nombre</td>
                    <td>@p.Telefono</td>
                    <td>@p.Direccion</td>
                    <td>@(p.Activo ? "Activo" : "Inactivo")</td>
                    <td>
                        <a href="/Proveedores/Edit/@p.ProveedorId" class="btn btn-warning btn-sm">Editar</a>
                        <a href="/Proveedores/Delete/@p.ProveedorId" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>