@model List<Lote>

<div class="container text-white">
    <h2>Lotes del Producto: @ViewBag.Producto.Nombre</h2>

    <div class="mb-3">
        <a href="/Producto" class="btn btn-secondary">← Volver a Productos</a>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="card bg-dark text-white">
                <div class="card-body">
                    <h5 class="card-title">Stock Total</h5>
                    <h3 class="text-success">@ViewBag.Producto.Stock unidades</h3>
                </div>
            </div>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>Número de Lote</th>
                        <th>Proveedor</th>
                        <th>Precio Compra</th>
                        <th>Cantidad Comprada</th>
                        <th>Fecha Compra</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lote in Model)
                    {
                        <tr>
                            <td><code>@lote.NumeroLote</code></td>
                            <td>
                                @if (lote.ProveedorId == 0)
                                {
                                    <span class="badge bg-secondary">Lote Inicial</span>
                                }
                                else
                                {
                                    @(lote.Proveedor?.Nombre ?? "Sin proveedor")
                                }
                            </td>
                            <td>
                                @if (lote.PrecioCompra == 0)
                                {
                                    <span class="text-muted">-</span>
                                }
                                else
                                {
                                    @("Q " + lote.PrecioCompra.ToString("F2"))
                                }
                            </td>
                            <td>@lote.CantidadComprada</td>
                            <td>@lote.FechaCompra.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No hay lotes registrados para este producto.
        </div>
    }
</div>