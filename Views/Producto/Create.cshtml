@model Producto

<div class="container text-white">
    <h2>Nuevo Producto</h2>
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}
    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label>Nombre</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Descripción</label>
            <input asp-for="Descripcion" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Precio Compra</label>
            <input asp-for="PrecioCompra" type="number" step="0.01" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Precio Venta</label>
            <input asp-for="PrecioVenta" type="number" step="0.01" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Stock</label>
            <input asp-for="Stock" type="number" class="form-control" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="Activo" class="form-check-input" />
            <label class="form-check-label">Activo</label>
        </div>

        <button type="submit" class="btn btn-success">
            Guardar
        </button>

        <a href="/Producto" class="btn btn-secondary">
            Cancelar
        </a>

    </form>
</div>