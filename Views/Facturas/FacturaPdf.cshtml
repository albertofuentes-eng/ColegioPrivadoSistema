@model Factura

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Factura @Model.NumeroFactura</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            color: #333;
        }
        .header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }
        .info {
            margin-bottom: 20px;
        }
        .info div {
            margin-bottom: 5px;
        }
        .total {
            font-size: 18px;
            font-weight: bold;
            text-align: right;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>BoutiqueGT</h1>
        <h2>Factura</h2>
    </div>

    <div class="info">
        <div><strong>Número de Factura:</strong> @Model.NumeroFactura</div>
        <div><strong>Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy")</div>
        <div><strong>Compra ID:</strong> @Model.CompraId</div>
        <div><strong>Empresa ID:</strong> @Model.EmpresaId</div>
    </div>

    <div class="total">
        <strong>Total: Q @Model.Total.ToString("N2")</strong>
    </div>
</body>
</html>