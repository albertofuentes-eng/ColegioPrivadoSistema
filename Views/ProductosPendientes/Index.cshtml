@{
    ViewData["Title"] = "Productos Pendientes";
}

<div class="container-fluid mt-4 text-white">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>📦 Productos Pendientes de Procesar</h2>
            <p class="text-muted">Seguimiento de productos desde compra hasta devolución o procesamiento</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Resumen")" class="btn btn-info">📊 Ver Resumen</a>
        </div>
    </div>

    <!-- FILTRO DE ESTADO -->
    <div class="mb-3">
        <div class="btn-group" role="group">
            <a href="@Url.Action("Index", new { estado = "Pendiente" })" 
               class="btn btn-outline-warning @(ViewBag.EstadoFiltro == "Pendiente" ? "active" : "")">
                ⏳ Pendientes
            </a>
            <a href="@Url.Action("Index", new { estado = "Procesado" })" 
               class="btn btn-outline-success @(ViewBag.EstadoFiltro == "Procesado" ? "active" : "")">
                ✅ Procesados
            </a>
            <a href="@Url.Action("Index", new { estado = "Cancelado" })" 
               class="btn btn-outline-danger @(ViewBag.EstadoFiltro == "Cancelado" ? "active" : "")">
                ❌ Cancelados
            </a>
        </div>
    </div>

    @if (Model?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Compra</th>
                        <th>Producto</th>
                        <th>Cantidad Total</th>
                        <th>Cantidad Procesada</th>
                        <th>Pendiente</th>
                        <th>% Progreso</th>
                        <th>Estado</th>
                        <th>Fecha Compra</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var porcentaje = item.Cantidad > 0 ? (item.CantidadProcesada * 100) / item.Cantidad : 0;
                        
                        <tr>
                            <td><strong>#@item.ProductoPendienteId</strong></td>
                            <td><strong>#@item.CompraId</strong></td>
                            <td>@item.Producto?.Nombre ?? "N/A"</td>
                            <td><span class="badge bg-primary">@item.Cantidad</span></td>
                            <td><span class="badge bg-info">@item.CantidadProcesada</span></td>
                            <td><span class="badge bg-warning text-dark">@(item.Cantidad - item.CantidadProcesada)</span></td>
                            <td>
                                <div class="progress" style="height: 1.25rem;">
                                    <div class="progress-bar @(porcentaje < 50 ? "bg-danger" : porcentaje < 100 ? "bg-warning" : "bg-success")" 
                                         role="progressbar" 
                                         style="width: @porcentaje%"
                                         aria-valuenow="@porcentaje" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                        @porcentaje%
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (item.Estado == "Pendiente")
                                {
                                    <span class="badge bg-warning text-dark">⏳ Pendiente</span>
                                }
                                else if (item.Estado == "Procesado")
                                {
                                    <span class="badge bg-success">✅ Procesado</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">❌ Cancelado</span>
                                }
                            </td>
                            <td>@item.FechaCompra.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a href="@Url.Action("Detalles", new { id = item.ProductoPendienteId })" 
                                   class="btn btn-sm btn-info">
                                    Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3 text-muted">
            <small>
                📌 Mostrando: <strong>@Model.Count()</strong> registros en estado "<strong>@ViewBag.EstadoFiltro</strong>"
            </small>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            ✓ No hay productos pendientes en estado "@ViewBag.EstadoFiltro"
        </div>
    }

    <!-- 💡 INFORMACIÓN ÚTIL -->
    <div class="mt-4">
        <div class="alert alert-info">
            <h6>ℹ️ Cómo Funciona</h6>
            <ul class="mb-0 small">
                <li><strong>Pendiente:</strong> Se compró el producto pero aún no se ha devuelto ni procesado</li>
                <li><strong>Procesado:</strong> Se devolvió el producto porque estaba dañado</li>
                <li><strong>Cancelado:</strong> Se registró una nota de crédito para este producto</li>
                <li><strong>% Progreso:</strong> Porcentaje de cantidad que ya fue procesada (devuelta o cancelada)</li>
            </ul>
        </div>
    </div>
</div>
