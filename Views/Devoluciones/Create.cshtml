@model DevolucionCompra

<div class="container text-white">
    <h2>Nueva Devolución</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

    <!-- 🆕 INFORMACIÓN IMPORTANTE -->
    <div class="alert alert-info mb-4">
        <h5>⚠️ Reglas de Devolución</h5>
        <ul>
            <li>✅ Solo se pueden devolver productos NO comprados en oferta</li>
            <li>✅ Devolución normal: El producto DEBE estar marcado como <strong>dañado</strong></li>
            <li>✅ Devolución por crédito: No requiere estar marcado como dañado (nota de crédito)</li>
            <li>✅ Límite: 7 días desde la compra</li>
        </ul>
    </div>

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label>Compra</label>
            <select name="CompraId" class="form-control">
                @foreach (var c in ViewBag.Compras)
                {
                    <option value="@c.CompraId">Compra #@c.CompraId</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Motivo</label>
            <input type="text" name="Motivo" class="form-control" />
        </div>

        <!-- 🔥 TIPO DEVOLUCIÓN -->
        <div class="mb-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="esCredito" name="EsCredito" value="true">
                <label class="form-check-label" for="esCredito">
                    Es nota de crédito
                </label>
            </div>
        </div>

        <div class="mb-3" id="totalCreditoDiv" style="display: none;">
            <label>Total de Crédito</label>
            <input type="number" step="0.01" name="TotalCredito" id="totalCredito" class="form-control" value="0" />
        </div>

        <hr />

        <h4>Agregar Producto</h4>

        <div class="row">
            <div class="col">
                <select id="producto" class="form-control">
                    @foreach (var p in ViewBag.Productos)
                    {
                        <option value="@p.ProductoId">@p.Nombre</option>
                    }
                </select>
            </div>

            <div class="col">
                <input type="number" id="cantidad" class="form-control" />
            </div>

            <!-- 🔥 NUEVO: DAÑADO -->
            <div class="col">
                <label>Dañado</label><br />
                <input type="checkbox" id="danado" />
            </div>

            <div class="col">
                <button type="button" onclick="agregar()" class="btn btn-success">
                    Agregar
                </button>
            </div>
        </div>

        <table class="table table-dark mt-3">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Dañado</th>
                </tr>
            </thead>
            <tbody id="tabla"></tbody>
        </table>

        <input type="hidden" name="DetalleJson" id="detalleJson" />

        <button class="btn btn-primary">Guardar</button>
    </form>
</div>

<script>
    let detalles = [];

    function toggleTotalCredito() {
        let esCredito = document.getElementById("esCredito").checked;
        let div = document.getElementById("totalCreditoDiv");
        if (esCredito) {
            div.style.display = "block";
        } else {
            div.style.display = "none";
            document.getElementById("totalCredito").value = "0";
        }
    }

    document.getElementById("esCredito").addEventListener("change", toggleTotalCredito);

    function agregar() {
        let select = document.getElementById("producto");
        let productoId = parseInt(select.value);
        let nombre = select.options[select.selectedIndex].text;
        let cantidad = parseInt(document.getElementById("cantidad").value);
        let danado = document.getElementById("danado").checked;

        detalles.push({
            ProductoId: productoId,
            Cantidad: cantidad,
            Danado: danado
        });

        document.getElementById("detalleJson").value = JSON.stringify(detalles);

        let fila = `
            <tr>
                <td>${nombre}</td>
                <td>${cantidad}</td>
                <td>${danado ? "Sí" : "No"}</td>
            </tr>
        `;

        document.getElementById("tabla").innerHTML += fila;
    }
</script>